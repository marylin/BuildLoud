# Required
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require
ANTHROPIC_API_KEY=your-api-key

# Optional: seo-engine integration (omit if not using seo-engine)
SEO_ENGINE_PATH=../seo-engine

# Optional: weekly digest email via Resend
RESEND_API_KEY=your-resend-key
DIGEST_EMAIL=you@example.com
DIGEST_FROM_EMAIL=Journey Logger <journal@yourdomain.com>

# Auto-detected from script location, override only if needed
# BUILD_LOG_PATH=/path/to/journey-logger
