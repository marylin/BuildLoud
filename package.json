{
  "name": "journey-logger",
  "version": "1.3.0",
  "description": "Zero-latency build-in-public journal for Claude Code",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "journey": "./bin/journey.js"
  },
  "scripts": {
    "test": "node --test tests/*.test.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prepare": "simple-git-hooks"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/marylin/journey-logger.git"
  },
  "author": "Marylin Ritchie <marylin@whateverai.com>",
  "license": "AGPL-3.0-only",
  "keywords": [
    "build-in-public",
    "journal",
    "claude-code",
    "developer-tools",
    "content-automation",
    "seo",
    "neon",
    "ai-agents"
  ],
  "homepage": "https://github.com/marylin/journey-logger",
  "bugs": {
    "url": "https://github.com/marylin/journey-logger/issues"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2"
  },
  "devDependencies": {
    "eslint": "^9.28.0",
    "@eslint/js": "^9.28.0",
    "prettier": "^3.5.3",
    "simple-git-hooks": "^2.13.0",
    "lint-staged": "^16.1.0"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  }
}
